generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────

enum UserRole {
  WORKER
  EMPLOYER
  BUSINESS
  AGENCY
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum JobStatus {
  DRAFT
  PENDING_PREFUND
  ACTIVE
  FILLED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ApplicationStatus {
  APPLIED
  QUEUED
  ACCEPTED
  REJECTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TransactionType {
  CREDIT
  DEBIT
  ESCROW_LOCK
  ESCROW_RELEASE
  ESCROW_REFUND
  SUBSCRIPTION_CHARGE
  WITHDRAWAL
  REFUND
  PLATFORM_FEE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_WORKER
  RESOLVED_EMPLOYER
  ESCALATED
  CLOSED
}

enum AttendanceStatus {
  NOT_STARTED
  CHECKED_IN
  CHECKED_OUT
  CONFIRMED
  PENDING_CONFIRMATION
  ABSENT
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  REFUNDED
}

// ─── USERS ───────────────────────────────────────

model User {
  id                String             @id @default(cuid())
  username          String?            @unique
  phone             String?            @unique
  email             String?            @unique
  passwordHash      String?
  role              UserRole
  isActive          Boolean            @default(true)
  isPhoneVerified   Boolean            @default(false)
  isEmailVerified   Boolean            @default(false)
  preferredLanguage String             @default("en")
  fcmToken          String?
  lastLoginAt       DateTime?
  onboardingState   String             @default("ANONYMOUS")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  workerProfile     WorkerProfile?
  employerProfile   EmployerProfile?
  businessProfile   BusinessProfile?
  wallet            Wallet?
  sentMessages      Message[]          @relation("SentMessages")
  receivedMessages  Message[]          @relation("ReceivedMessages")
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  sosAlerts         SosAlert[]
  // HZLR.store
  merchantProfile   MerchantProfile?
  cart              Cart?
  storeOrders       StoreOrder[]
}

model WorkerProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  photoUrl          String?
  dateOfBirth       DateTime?
  gender            String?
  city              String?
  state             String?
  pincode           String?
  address           String?
  latitude          Float?
  longitude         Float?
  bio               String?
  skills            String[]
  categories        String[]
  education         String?
  age               Int?
  aadhaarNumber     String?
  aadhaarVerified   Boolean            @default(false)
  aadhaarVerifiedAt DateTime?
  kycStatus         VerificationStatus @default(UNVERIFIED)
  kycAttempts       Int                @default(0)
  groomingCertified Boolean            @default(false)
  groomingBadges    String[]
  reliabilityScore  Float              @default(0)
  totalGigsDone     Int                @default(0)
  avgPay            Float              @default(0)
  isReadyToWork     Boolean            @default(false)
  isAvailable       Boolean            @default(true)
  subscriptionStatus SubscriptionStatus?
  subscriptionAmount Float?
  subscriptionDue   DateTime?
  lastSubscriptionPaidAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  applications      Application[]
  ratings           Rating[]           @relation("WorkerRatings")
  givenRatings      Rating[]           @relation("WorkerGivenRatings")
  attendance        Attendance[]
  disputes          Dispute[]          @relation("WorkerDisputes")
  // HZLR.store
  isDeliveryPartner   Boolean            @default(false)
  deliveryPartnerMode DeliveryPartnerMode?
}

model EmployerProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName           String
  lastName            String
  photoUrl            String?
  city                String?
  state               String?
  employerType        String    @default("individual")
  companyName         String?
  businessType        String?
  gstin               String?
  gstVerified         Boolean   @default(false)
  gstVerifiedAt       DateTime?
  gstLegalName        String?
  gstStatus           String?
  gstTurnoverSlab     String?
  registeredAddress   String?
  operatingCities     String[]
  logoUrl             String?
  website             String?
  contactPerson       String?
  designation         String?
  workerCategories    String[]
  monthlyHiringVolume String?
  preferredHiringMode String?
  hiringFrequency     String?
  onboardingStep      Int       @default(1)
  onboardingComplete  Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  jobs              Job[]
  ratings           Rating[]           @relation("EmployerRatings")
}

model BusinessProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName      String
  businessType      String
  logoUrl           String?
  gstNumber         String?
  isVerified        Boolean            @default(false)
  verifiedAt        DateTime?
  city              String?
  state             String?
  address           String?
  tier              String             @default("basic")
  tierExpiresAt     DateTime?
  totalHires        Int                @default(0)
  fillRate          Float              @default(0)
  avgFillTime       Float              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  jobs              Job[]
  disputes          Dispute[]          @relation("BusinessDisputes")
}

// ─── JOBS ────────────────────────────────────────

model Job {
  id                String             @id @default(cuid())
  employerProfileId String?
  businessProfileId String?
  employerProfile   EmployerProfile?   @relation(fields: [employerProfileId], references: [id])
  businessProfile   BusinessProfile?   @relation(fields: [businessProfileId], references: [id])
  title             String
  description       String
  category          String
  skills            String[]
  payPerWorker      Float
  totalSpots        Int
  filledSpots       Int                @default(0)
  isPrefunded       Boolean            @default(false)
  prefundedAt       DateTime?
  scheduledFor      DateTime
  estimatedHours    Float?
  isInstant         Boolean            @default(false)
  city              String
  state             String
  address           String
  latitude          Float
  longitude         Float
  status            JobStatus          @default(DRAFT)
  cancelledAt       DateTime?
  cancelReason      String?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  applications      Application[]
  escrowHold        EscrowHold?
  attendance        Attendance[]
  disputes          Dispute[]
  ratings           Rating[]
}

// ─── APPLICATIONS ────────────────────────────────

model Application {
  id                String             @id @default(cuid())
  jobId             String
  job               Job                @relation(fields: [jobId], references: [id])
  workerProfileId   String
  workerProfile     WorkerProfile      @relation(fields: [workerProfileId], references: [id])
  status            ApplicationStatus  @default(APPLIED)
  queuePosition     Int?
  appliedAt         DateTime           @default(now())
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  attendance        Attendance?

  @@unique([jobId, workerProfileId])
}

// ─── WALLET & ESCROW ─────────────────────────────

model Wallet {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance           Float              @default(0)
  pendingBalance    Float              @default(0)
  escrowBalance     Float              @default(0)
  totalEarned       Float              @default(0)
  totalWithdrawn    Float              @default(0)
  upiId             String?
  upiVerified       Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  transactions      Transaction[]
}

model Transaction {
  id                String             @id @default(cuid())
  walletId          String
  wallet            Wallet             @relation(fields: [walletId], references: [id])
  type              TransactionType
  amount            Float
  description       String
  reference         String?
  jobId             String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String             @default("completed")
  metadata          Json?
  createdAt         DateTime           @default(now())
}

model EscrowHold {
  id                String             @id @default(cuid())
  jobId             String             @unique
  job               Job                @relation(fields: [jobId], references: [id])
  amount            Float
  status            String             @default("held")
  heldAt            DateTime           @default(now())
  releasedAt        DateTime?
  refundedAt        DateTime?
  razorpayOrderId   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// ─── RATINGS ─────────────────────────────────────

model Rating {
  id                String             @id @default(cuid())
  jobId             String
  job               Job                @relation(fields: [jobId], references: [id])
  workerProfileId   String
  workerProfile     WorkerProfile      @relation("WorkerRatings", fields: [workerProfileId], references: [id])
  givenByWorker     WorkerProfile?     @relation("WorkerGivenRatings", fields: [givenByWorkerId], references: [id])
  givenByWorkerId   String?
  employerProfileId String?
  employerProfile   EmployerProfile?   @relation("EmployerRatings", fields: [employerProfileId], references: [id])
  raterRole         String
  score             Int
  review            String?
  isPublic          Boolean            @default(true)
  createdAt         DateTime           @default(now())

  @@unique([jobId, workerProfileId, raterRole])
}

// ─── ATTENDANCE ──────────────────────────────────

model Attendance {
  id                String             @id @default(cuid())
  jobId             String
  job               Job                @relation(fields: [jobId], references: [id])
  applicationId     String             @unique
  application       Application        @relation(fields: [applicationId], references: [id])
  workerProfileId   String
  workerProfile     WorkerProfile      @relation(fields: [workerProfileId], references: [id])
  status            AttendanceStatus   @default(NOT_STARTED)
  checkInTime       DateTime?
  checkInLat        Float?
  checkInLng        Float?
  checkInDistance   Float?
  checkInMethod     String?
  checkOutTime      DateTime?
  checkOutLat       Float?
  checkOutLng       Float?
  checkOutMethod    String?
  confirmedAt       DateTime?
  confirmedBy       String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// ─── DISPUTES ────────────────────────────────────

model Dispute {
  id                String             @id @default(cuid())
  jobId             String
  job               Job                @relation(fields: [jobId], references: [id])
  workerProfileId   String?
  workerProfile     WorkerProfile?     @relation("WorkerDisputes", fields: [workerProfileId], references: [id])
  businessProfileId String?
  businessProfile   BusinessProfile?   @relation("BusinessDisputes", fields: [businessProfileId], references: [id])
  raisedBy          String
  reason            String
  description       String
  evidence          String[]
  status            DisputeStatus      @default(OPEN)
  resolution        String?
  resolvedBy        String?
  resolvedAt        DateTime?
  escrowAction      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// ─── MESSAGES ────────────────────────────────────

model Message {
  id                String             @id @default(cuid())
  senderId          String
  sender            User               @relation("SentMessages", fields: [senderId], references: [id])
  receiverId        String
  receiver          User               @relation("ReceivedMessages", fields: [receiverId], references: [id])
  jobId             String?
  content           String
  isRead            Boolean            @default(false)
  readAt            DateTime?
  createdAt         DateTime           @default(now())
}

// ─── NOTIFICATIONS ───────────────────────────────

model Notification {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  type              String
  title             String
  body              String
  data              Json?
  isRead            Boolean            @default(false)
  readAt            DateTime?
  createdAt         DateTime           @default(now())
}

// ─── SOS ─────────────────────────────────────────

model SosAlert {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  jobId             String?
  latitude          Float
  longitude         Float
  description       String?
  status            String             @default("active")
  resolvedAt        DateTime?
  createdAt         DateTime           @default(now())
}

// ─── AUTH ────────────────────────────────────────

model OtpCode {
  id                String             @id @default(cuid())
  phone             String?
  email             String?
  code              String
  expiresAt         DateTime
  isUsed            Boolean            @default(false)
  createdAt         DateTime           @default(now())
}

model RefreshToken {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  token             String             @unique
  expiresAt         DateTime
  createdAt         DateTime           @default(now())
}

// ─── HZLR.STORE ENUMS ────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum StorePaymentMethod {
  RAZORPAY
  COD
}

enum DispatchStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  COMPLETED
}

enum MerchantStatus {
  PENDING_APPROVAL
  APPROVED
  SUSPENDED
}

// ─── HZLR.STORE — MERCHANT ───────────────────────

model MerchantProfile {
  id                   String          @id @default(cuid())
  userId               String          @unique
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName            String
  storeType            String          // supermarket | kirana | pharmacy | bakery | restaurant
  tagline              String?
  logoUrl              String?
  description          String?
  // Location
  address              String
  city                 String
  state                String
  pincode              String?
  latitude             Float
  longitude            Float
  // Hours: JSON array of { day: "Mon", open: "08:00", close: "22:00", closed: false }
  operatingHours       Json?
  // Delivery config
  minOrderValue        Float           @default(0)
  maxDeliveryRadiusKm  Float           @default(5)
  freeDeliveryThreshold Float?
  // POS integration
  posType              String?         // petpooja | gofrugal | csv | none
  posMerchantId        String?
  posWebhookSecret     String?
  // Approval
  status               MerchantStatus  @default(PENDING_APPROVAL)
  approvedAt           DateTime?
  approvedBy           String?
  suspendedAt          DateTime?
  suspendReason        String?
  // Payout
  upiId                String?
  // Ratings
  avgRating            Float           @default(0)
  totalRatings         Int             @default(0)
  totalOrders          Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  products             Product[]
  orders               StoreOrder[]
  posSync              PosSync[]
  settlements          Settlement[]
  subscription         MerchantSubscription?
}

// ─── HZLR.STORE — CATALOG ────────────────────────

model ProductCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  iconEmoji   String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())

  products    Product[]
}

model Product {
  id               String          @id @default(cuid())
  merchantId       String
  merchant         MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         ProductCategory? @relation(fields: [categoryId], references: [id])
  name             String
  description      String?
  imageUrl         String?
  price            Float
  mrp              Float?
  unit             String          @default("piece") // piece | kg | litre | pack | dozen
  stock            Int             @default(0)
  lowStockThreshold Int            @default(5)
  isActive         Boolean         @default(true)
  sku              String?
  barcode          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  cartItems        CartItem[]
  orderItems       StoreOrderItem[]
}

model PosSync {
  id            String          @id @default(cuid())
  merchantId    String
  merchant      MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  posType       String
  itemsUpdated  Int             @default(0)
  status        String          @default("success") // success | failed | partial
  errorMessage  String?
  syncedAt      DateTime        @default(now())
}

// ─── HZLR.STORE — CART ───────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     CartItem[]
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      @default(1)
  priceAtAdd  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, productId])
}

// ─── HZLR.STORE — ORDERS ─────────────────────────

model StoreOrder {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  merchantId        String
  merchant          MerchantProfile    @relation(fields: [merchantId], references: [id])
  status            OrderStatus        @default(PENDING_PAYMENT)
  paymentMethod     StorePaymentMethod
  // Financials (snapshot at order time)
  subtotal          Float
  deliveryFee       Float
  totalAmount       Float
  // Delivery address (snapshot)
  deliveryAddress   String
  deliveryLat       Float?
  deliveryLng       Float?
  // Razorpay
  razorpayOrderId   String?
  razorpayPaymentId String?
  // Timestamps
  confirmedAt       DateTime?
  preparedAt        DateTime?
  readyAt           DateTime?
  assignedAt        DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  items             StoreOrderItem[]
  assignment        DeliveryAssignment?
  settlement        Settlement?        @relation(fields: [settlementId], references: [id])
  settlementId      String?
}

model StoreOrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  productName String     // snapshot — immutable
  quantity    Int
  unitPrice   Float      // price at order time — immutable
  totalPrice  Float
  createdAt   DateTime   @default(now())
}

// ─── HZLR.STORE — DELIVERY ───────────────────────

model DeliveryPartnerMode {
  id            String        @id @default(cuid())
  workerProfileId String      @unique
  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  isOnline      Boolean       @default(false)
  vehicleType   String        @default("two-wheeler") // bicycle | two-wheeler | three-wheeler
  currentLat    Float?
  currentLng    Float?
  lastSeenAt    DateTime?
  totalDeliveries Int         @default(0)
  totalEarned   Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assignments   DeliveryAssignment[]
  subscription  DeliverySubPayment?
}

model DeliveryAssignment {
  id                  String              @id @default(cuid())
  orderId             String              @unique
  order               StoreOrder          @relation(fields: [orderId], references: [id])
  deliveryPartnerId   String
  deliveryPartner     DeliveryPartnerMode @relation(fields: [deliveryPartnerId], references: [id])
  status              DispatchStatus      @default(PENDING)
  distanceKm          Float?
  baseEarning         Float?
  sizeBonus           Float?
  totalEarning        Float?
  pushedAt            DateTime            @default(now())
  acceptedAt          DateTime?
  pickedUpAt          DateTime?
  deliveredAt         DateTime?
  declinedAt          DateTime?
  declineReason       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

// ─── HZLR.STORE — SETTLEMENTS ────────────────────

model Settlement {
  id           String          @id @default(cuid())
  merchantId   String
  merchant     MerchantProfile @relation(fields: [merchantId], references: [id])
  periodStart  DateTime
  periodEnd    DateTime
  totalOrders  Int             @default(0)
  grossRevenue Float           @default(0)
  platformFee  Float           @default(0)
  netPayout    Float           @default(0)
  status       String          @default("PENDING") // PENDING | PROCESSING | PROCESSED | FAILED
  processedAt  DateTime?
  failureReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  orders       StoreOrder[]
}

// ─── HZLR.STORE — CONFIG ─────────────────────────

model DeliveryFeeConfig {
  id           String   @id @default(cuid())
  baseFee      Float    @default(20)
  ratePerKm    Float    @default(6)
  // JSON: [{ min_order: 0, max_order: 300, bonus: 0 }, ...]
  sizeBrackets Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── HZLR.STORE — SUBSCRIPTIONS ──────────────────

model MerchantSubscription {
  id          String             @id @default(cuid())
  merchantId  String             @unique
  merchant    MerchantProfile    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  planName    String             @default("standard") // standard | premium
  monthlyFee  Float
  status      SubscriptionStatus @default(ACTIVE)
  startedAt   DateTime           @default(now())
  nextDueAt   DateTime?
  lastPaidAt  DateTime?
  razorpaySubId String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model DeliverySubPayment {
  id                  String              @id @default(cuid())
  deliveryPartnerId   String              @unique
  deliveryPartner     DeliveryPartnerMode @relation(fields: [deliveryPartnerId], references: [id], onDelete: Cascade)
  monthlyFee          Float
  status              SubscriptionStatus  @default(ACTIVE)
  startedAt           DateTime            @default(now())
  nextDueAt           DateTime?
  lastPaidAt          DateTime?
  razorpaySubId       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}
